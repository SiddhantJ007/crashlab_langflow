# Langflow service runtime
LANGFLOW_HOST=0.0.0.0
LANGFLOW_PORT=7860
LANGFLOW_LOG_LEVEL=info
LANGFLOW_DATABASE_URL=sqlite:////opt/render/project/src/langflow-data/langflow.db
LANGFLOW_CONFIG_DIR=/opt/render/project/src/langflow-data
LANGFLOW_AUTO_LOGIN=false

# Provider credentials used inside your deployed Langflow flow
OPENAI_API_KEY=your_model_provider_key_here

# Optional UI/admin values if you choose to lock down the instance
LANGFLOW_SUPERUSER=admin@example.com
LANGFLOW_SUPERUSER_PASSWORD=change_me
